#!/usr/bin/env bash
# pre-push: refuse to push if routines/<name>.md is out of sync with its
# .claude/commands/<name>.md source. Catches the failure mode where a STEP
# edit lands in source but the regenerated routine is forgotten in a
# commit, so the cloud runs stale instructions.
#
# Enable:   bash scripts/install-githooks.sh   (sets core.hooksPath = .githooks)
# Bypass:   git push --no-verify               (use with care)

set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

# The hook runs on a clean working tree before push. Regenerate in place
# and assert no diff in routines/. If there is a diff, the user forgot to
# regenerate after editing .claude/commands/<name>.md — they should run
# the script and commit the result before pushing.
bash scripts/build-routines.sh >/dev/null

if ! git diff --quiet -- routines/; then
  echo "pre-push: routines/ is out of sync with .claude/commands/." >&2
  echo "  Run: bash scripts/build-routines.sh" >&2
  echo "  Then commit the regenerated files and push again." >&2
  echo "  (or pass --no-verify if this is a docs-only push)" >&2
  git diff --stat -- routines/ >&2
  exit 1
fi

# Same idea for the cloud bot registry — when a user adds/edits bots in
# the dashboard, dashboard-settings.json updates locally but the
# committed bots-registry.json (which is what cloud routines actually
# read) stays stale. Regenerate and assert no drift.
#
# Skip silently if dashboard-settings.json doesn't exist on this machine —
# someone with a clean clone can't sync what they don't have, and the
# committed registry file is authoritative for them.
if [[ -f memory/shared/dashboard-settings.json ]]; then
  bash scripts/sync-bots-registry.sh >/dev/null
  if ! git diff --quiet -- memory/shared/bots-registry.json; then
    echo "pre-push: memory/shared/bots-registry.json is out of sync with dashboard-settings.json." >&2
    echo "  Run: bash scripts/sync-bots-registry.sh" >&2
    echo "  Then commit the regenerated file and push again." >&2
    git diff --stat -- memory/shared/bots-registry.json >&2
    exit 1
  fi
fi

exit 0
