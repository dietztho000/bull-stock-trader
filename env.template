# ─── Single-bot legacy mode ─────────────────────────────────────────────
# These vars drive the bot when there are no entries in the dashboard
# registry (memory/shared/dashboard-settings.json). For multi-bot setups,
# the dashboard manages credentials in an encrypted vault — see the
# "Multi-bot vault" section below.

# Alpaca — LIVE trading (default mode)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
# optional — defaults to live URLs
ALPACA_ENDPOINT=https://api.alpaca.markets/v2
ALPACA_DATA_ENDPOINT=https://data.alpaca.markets/v2

# Alpaca — PAPER trading (set BOT_MODE=paper to use these)
# optional — only required when BOT_MODE=paper
# ALPACA_PAPER_API_KEY=your_paper_api_key_here
# ALPACA_PAPER_SECRET_KEY=your_paper_secret_key_here
# ALPACA_PAPER_ENDPOINT=https://paper-api.alpaca.markets/v2

# Mode switch — "live" (default) or "paper". Use paper to dry-run rule
# changes for ~30 days before promoting them. In multi-bot mode, BOT_MODE
# is overridden per fan-out iteration by scripts/bots.sh.
# BOT_MODE=paper

# ─── Multi-bot vault (dashboard-managed) ────────────────────────────────
# When you add accounts via the dashboard (/bots → Add account), the
# dashboard encrypts API key + secret with AES-256-GCM keyed by
# BULL_VAULT_KEY and stores the ciphertext in
# memory/shared/dashboard-settings.json (gitignored). The cloud routines
# resolve creds either via the vault (when BULL_VAULT_KEY is set in the
# routine env) or via namespaced env vars (a per-account fallback).

# 32-byte key in base64. Generate via the dashboard: Settings → Vault →
# Generate, or:
#   node -e 'console.log(require("crypto").randomBytes(32).toString("base64"))'
# BULL_VAULT_KEY=base64-32-bytes-here

# Namespaced fallback: when BULL_VAULT_KEY is unset, scripts/alpaca.sh
# resolves --account-id=<slug> to env vars by upper-snake-casing the slug.
# Account slug "paper-100k" → ALPACA_PAPER_100K_API_KEY / _SECRET_KEY.
# Useful for cloud routines that prefer env-only setup over the vault.
# ALPACA_PAPER_100K_API_KEY=...
# ALPACA_PAPER_100K_SECRET_KEY=...
# ALPACA_PAPER_100K_ENDPOINT=https://paper-api.alpaca.markets/v2

# ─── Research ───────────────────────────────────────────────────────────

# Perplexity (research)
PERPLEXITY_API_KEY=your_perplexity_api_key_here
# optional — defaults to "sonar"
PERPLEXITY_MODEL=sonar

# ─── Notifications ──────────────────────────────────────────────────────

# Discord (notifications — posts to a channel via webhook)
# Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy Webhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_id/your_token

# Optional per-category webhook overrides. Each falls back to
# DISCORD_WEBHOOK_URL above when unset. Categories: research, fill, midday,
# stops, eod, weekly, error, auth-canary, alert. Hyphens in category names
# map to underscores in the env-var name (auth-canary → AUTH_CANARY).
# DISCORD_WEBHOOK_URL_EOD=...          # daily summary channel
# DISCORD_WEBHOOK_URL_WEEKLY=...       # weekly review channel
# DISCORD_WEBHOOK_URL_ERROR=...        # alert channel for in-flight workflow failures
# DISCORD_WEBHOOK_URL_FILL=...         # trade-fill channel
# DISCORD_WEBHOOK_URL_MIDDAY=...       # midday-action channel
# DISCORD_WEBHOOK_URL_STOPS=...        # stop-reconciliation channel
# DISCORD_WEBHOOK_URL_RESEARCH=...     # pre-market research channel
                                       #   (also used by the dashboard's
                                       #   "Pre-Market Discord Brief" button —
                                       #   the dashboard /settings page can
                                       #   override this per-machine without
                                       #   editing .env)
# DISCORD_WEBHOOK_URL_AUTH_CANARY=...  # 3:30am auth-canary health checks
# DISCORD_WEBHOOK_URL_ALERT=...        # price-monitor early warnings (-5/-6/-7%)

# ntfy.sh push-notification mirror (optional — boring-tech redundancy)
# Pick a long, hard-to-guess topic name; subscribe to it on your phone via
# the ntfy.sh app. --type=alert routes to ntfy ONLY when this is set
# (keeps high-frequency price-monitor warnings off the Discord rate limit).
# NTFY_TOPIC=bull-stock-trader-<random-suffix>

# ─── Dashboard ──────────────────────────────────────────────────────────

# Anthropic — dashboard AI features (chat, post-mortems, drawdown narrator,
# weekly-review draft). Only used by the dashboard; the bot itself does not
# call this. Get a key at console.anthropic.com. The dashboard reads it
# from .env.local in dashboard/.
# ANTHROPIC_API_KEY=sk-ant-...
