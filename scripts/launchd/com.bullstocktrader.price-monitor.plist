<?xml version="1.0" encoding="UTF-8"?>
<!--
  launchd agent: polls Alpaca positions every 10 min and posts an early-
  warning Discord message the first time a position drops into each -1%
  bucket at or below -5%. Doesn't trade. The script self-gates on
  alpaca.sh clock — off-hours runs exit immediately after one cheap call.

  Install:
    cp scripts/launchd/com.bullstocktrader.price-monitor.plist \
       ~/Library/LaunchAgents/com.bullstocktrader.price-monitor.plist
    launchctl bootstrap "gui/$(id -u)" \
       ~/Library/LaunchAgents/com.bullstocktrader.price-monitor.plist

  Trigger immediately (skip the 10-minute wait):
    launchctl kickstart -k "gui/$(id -u)/com.bullstocktrader.price-monitor"

  Inspect:
    launchctl print "gui/$(id -u)/com.bullstocktrader.price-monitor"
    tail -f ~/Library/Logs/bull-stock-trader-price-monitor.out.log

  Uninstall:
    launchctl bootout "gui/$(id -u)/com.bullstocktrader.price-monitor"
    rm ~/Library/LaunchAgents/com.bullstocktrader.price-monitor.plist
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.bullstocktrader.price-monitor</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/dietz/Desktop/Apps/bull-stock-trader/scripts/price-monitor.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/dietz/Desktop/Apps/bull-stock-trader</string>

    <key>StartInterval</key>
    <integer>600</integer>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/Users/dietz/Library/Logs/bull-stock-trader-price-monitor.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/dietz/Library/Logs/bull-stock-trader-price-monitor.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
