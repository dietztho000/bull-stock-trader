<?xml version="1.0" encoding="UTF-8"?>
<!--
  launchd agent: pulls cloud-routine memory writes into local main every 15 min.

  Install:
    cp scripts/launchd/com.bullstocktrader.cloud-sync.plist \
       ~/Library/LaunchAgents/com.bullstocktrader.cloud-sync.plist
    launchctl bootstrap "gui/$(id -u)" \
       ~/Library/LaunchAgents/com.bullstocktrader.cloud-sync.plist

  Trigger immediately (skip the 15-minute wait):
    launchctl kickstart -k "gui/$(id -u)/com.bullstocktrader.cloud-sync"

  Inspect:
    launchctl print "gui/$(id -u)/com.bullstocktrader.cloud-sync"
    tail -f ~/Library/Logs/bull-stock-trader-sync.out.log

  Uninstall:
    launchctl bootout "gui/$(id -u)/com.bullstocktrader.cloud-sync"
    rm ~/Library/LaunchAgents/com.bullstocktrader.cloud-sync.plist
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.bullstocktrader.cloud-sync</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/dietz/Desktop/Apps/bull-stock-trader/scripts/cron-sync.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/dietz/Desktop/Apps/bull-stock-trader</string>

    <key>StartInterval</key>
    <integer>900</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/dietz/Library/Logs/bull-stock-trader-sync.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/dietz/Library/Logs/bull-stock-trader-sync.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
